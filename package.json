{
  "name": "paypilot-ai",
  "version": "0.0.1",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "format": "turbo run format",
    "test": "turbo run test",
    "type-check": "turbo run type-check",
    "verify": "turbo run lint type-check test build",
    "dev:backend": "turbo run dev --filter=@paypilot/backend",
    "dev:frontend": "turbo run dev --filter=@paypilot/frontend"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.2",
    "turbo": "^2.5.0"
  }
}
