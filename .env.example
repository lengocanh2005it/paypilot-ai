# ═══════════════════════════════════════════════════════════
# PayPilot AI — Environment Variables
# ═══════════════════════════════════════════════════════════
# Copy file này thành .env và điền giá trị thật.
# KHÔNG commit file .env lên Git (đã có trong .gitignore).

# ───────────────────────────────────────────────────────────
# APP
# ───────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
APP_URL=http://localhost:3000
FRONTEND_URL=http://localhost:5173

# ───────────────────────────────────────────────────────────
# DATABASE (PostgreSQL + pgvector)
# ───────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:password@localhost:5432/paypilot_ai
POSTGRES_USER=postgres
POSTGRES_PASSWORD=password
POSTGRES_DB=paypilot_ai
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# ───────────────────────────────────────────────────────────
# REDIS (Cache + BullMQ)
# ───────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_URL=redis://localhost:6379

# ───────────────────────────────────────────────────────────
# JWT AUTHENTICATION
# ───────────────────────────────────────────────────────────
JWT_ACCESS_SECRET=your_jwt_access_secret_change_me
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_SECRET=your_jwt_refresh_secret_change_me
JWT_REFRESH_EXPIRES_IN=7d

# ───────────────────────────────────────────────────────────
# OPENAI API (do công ty cấp sẵn)
# ───────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_CHAT_MODEL=gpt-4o-mini

# ───────────────────────────────────────────────────────────
# CAS SDK — Balance Hook (Banking — SANDBOX THẬT)
# Lấy tại: https://sandbox.console.bankhub.dev/developer/keys
# Docs: https://cas.so/quickstart
# ───────────────────────────────────────────────────────────
CAS_API_BASE_URL=https://sandbox.bankhub.dev
CAS_API_VERSION=2023-01-01
CAS_CLIENT_ID=your_client_id_from_console
CAS_SECRET_KEY=your_secret_key_from_console
CAS_GRANT_REDIRECT_URI=http://localhost:5173/onboarding/callback
# Đổi sang production khi go-live thật:
# CAS_API_BASE_URL=https://production.bankhub.dev

# ───────────────────────────────────────────────────────────
# CAS WEBHOOK (Balance Hook) — 1 URL CHUNG cho toàn App
# Cấu hình tại: sandbox.console.bankhub.dev → Developer → Webhooks
# Loại: TRANSACTIONS
# Dev local: dùng `ngrok http 3000` để tạo URL public, vì Cas
# server thật KHÔNG gọi vào được localhost
# ───────────────────────────────────────────────────────────
# Ví dụ sau khi chạy ngrok: https://abc123.ngrok-free.app/api/v1/webhook/cas
NGROK_WEBHOOK_URL=

# ───────────────────────────────────────────────────────────
# PAYOS — CHỈ dùng cho Billing (PayPilot thu phí doanh nghiệp
# khi nâng cấp gói). KHÔNG dùng cho nghiệp vụ đối soát giao dịch
# (việc đó đã chuyển sang QR ngân hàng công khai qua Cas).
# Đây là 1 account PayOS DUY NHẤT thuộc về PayPilot, không phải
# của từng doanh nghiệp.
# Chưa đăng ký tài khoản thật — webhook callback mock bằng Postman
# ───────────────────────────────────────────────────────────
PAYOS_CHECKSUM_KEY=mock_checksum_for_testing_only
PAYOS_BILLING_WEBHOOK_URL=http://localhost:3000/api/v1/webhook/payos-billing

# ───────────────────────────────────────────────────────────
# WEBHOOK SECURITY
# LƯU Ý: Tài liệu Cas Balance Hook chưa nêu rõ tên header chữ ký
# (khác Casso dùng X-Casso-Signature). Cần kiểm tra lại
# https://cas.so/general/api/webhook khi code thật.
# QUAN TRỌNG: field "grantId" trong payload CHỈ dùng để routing
# đúng tenant (query bảng cas_grants), KHÔNG phải cơ chế xác thực
# tính toàn vẹn — vẫn cần verify webhook có đến từ Cas thật hay không.
# ───────────────────────────────────────────────────────────
WEBHOOK_SIGNATURE_HEADER=X-Cas-Signature
WEBHOOK_TIMESTAMP_TOLERANCE_SECONDS=300
WEBHOOK_IDEMPOTENCY_TTL_SECONDS=86400
WEBHOOK_SKIP_SIGNATURE_VERIFY=false

# ───────────────────────────────────────────────────────────
# AI MATCHING CONFIG
# ───────────────────────────────────────────────────────────
AI_MATCHING_AUTO_THRESHOLD=95
AI_MATCHING_MIN_THRESHOLD=50

# ───────────────────────────────────────────────────────────
# NOTIFICATION
# ───────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password
SMTP_FROM=PayPilot AI <noreply@paypilot.ai>

SLACK_WEBHOOK_URL=
DISCORD_WEBHOOK_URL=

# ───────────────────────────────────────────────────────────
# RATE LIMITING
# ───────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100
AUTH_RATE_LIMIT_MAX_ATTEMPTS=5

# ───────────────────────────────────────────────────────────
# LOGGING & OBSERVABILITY
# ───────────────────────────────────────────────────────────
LOG_LEVEL=debug
# LOG_LEVEL=info (production)

# ───────────────────────────────────────────────────────────
# CORS
# ───────────────────────────────────────────────────────────
CORS_ORIGIN=http://localhost:5173

# ───────────────────────────────────────────────────────────
# FRONTEND (.env riêng cho React, prefix VITE_)
# ───────────────────────────────────────────────────────────
# VITE_API_BASE_URL=http://localhost:3000/api/v1
